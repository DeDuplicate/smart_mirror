# ===========================================
# Smart Mirror Display — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# Google OAuth (for Calendar & Tasks integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spotify (for music playback control)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Home Assistant (for smart-home entity control)
HA_HOST=http://homeassistant.local:8123
HA_TOKEN=

# Token encryption secret (used to encrypt OAuth tokens at rest)
# If not set, a random key is auto-generated on first run and stored in the DB.
TOKEN_SECRET=

# Backend server
PORT=3001
NODE_ENV=production
